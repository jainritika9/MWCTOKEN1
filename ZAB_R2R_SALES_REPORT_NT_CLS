*&---------------------------------------------------------------------*
*& Include ZAB_R2R_SALES_REPORT_NT_CLS
*&---------------------------------------------------------------------*

CLASS lcl_events DEFINITION.
  PUBLIC SECTION.
    " Handler for flat ALV (SJ / SL mode)
    METHODS on_added_function
      FOR EVENT added_function OF cl_salv_events_table
      IMPORTING e_salv_function.
    " Handler for hierarchical ALV (DL mode)
    METHODS on_added_function_hier
      FOR EVENT added_function OF cl_salv_events_hierseq
      IMPORTING e_salv_function.
  PRIVATE SECTION.
    METHODS handle_function
      IMPORTING iv_function TYPE salv_de_function.
ENDCLASS.

CLASS lcl_events IMPLEMENTATION.

  METHOD on_added_function.
    handle_function( iv_function = e_salv_function ).
  ENDMETHOD.

  METHOD on_added_function_hier.
    handle_function( iv_function = e_salv_function ).
  ENDMETHOD.

  METHOD handle_function.

    CONSTANTS:
      lc_title  TYPE string VALUE 'Save File',
      lc_filter TYPE string
        VALUE 'All Files (*.*)|*.*|Data (*.dat)|*.dat|CSV (*.csv)|*.csv|Excel (*.xls)|*.xls'.

    DATA:
      lv_filename  TYPE string,
      lv_path      TYPE string,
      lv_fullpath  TYPE string,
      lv_ext       TYPE string,
      lv_defname   TYPE string,
      lv_separator TYPE c.

    CASE iv_function.
      WHEN 'EDAT'.
        lv_defname   = 'Sales_NonTrade_Summary.dat'.
        lv_ext       = 'DAT'.
        lv_separator = space.
      WHEN 'ECSV'.
        lv_defname   = 'Sales_NonTrade_Summary.csv'.
        lv_ext       = 'CSV'.
        lv_separator = ','.
      WHEN 'EXLS'.
        lv_defname   = 'Sales_NonTrade_Summary.xls'.
        lv_ext       = 'XLS'.
        lv_separator = cl_abap_char_utilities=>horizontal_tab.
      WHEN OTHERS.
        RETURN.
    ENDCASE.

    PERFORM get_filedata.

    cl_gui_frontend_services=>file_save_dialog(
      EXPORTING
        window_title      = lc_title
        default_extension = lv_ext
        default_file_name = lv_defname
        file_filter       = lc_filter
      CHANGING
        filename  = lv_filename
        path      = lv_path
        fullpath  = lv_fullpath
      EXCEPTIONS OTHERS = 1 ).

    CHECK lv_fullpath IS NOT INITIAL.

    cl_gui_frontend_services=>gui_download(
      EXPORTING
        filename              = lv_fullpath
        filetype              = 'ASC'
        write_field_separator = lv_separator
      CHANGING
        data_tab = gt_out_tab
      EXCEPTIONS OTHERS = 1 ).

  ENDMETHOD.

ENDCLASS.
