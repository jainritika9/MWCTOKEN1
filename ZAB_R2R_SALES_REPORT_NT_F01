*&---------------------------------------------------------------------*
*& Include ZAB_R2R_SALES_REPORT_NT_F01
*&---------------------------------------------------------------------*

*======================================================================*
* FORM: get_data
* Reads all data from DB, calls process_data to build output tables.
* CDS views used: I_JournalEntry, I_JournalEntryItem, I_GLAccount,
*                 I_GLAccountText, I_CustomerSalesArea, I_CompanyCode
* Direct tables : TVARVC (no CDS), dfkkbptaxnum (IS-U FI-CA),
*                 but020/adrc (BP address subfields), zdt_r2r_fl_gls (Z)
*======================================================================*
FORM get_data.

  "--- 1. Read TVARVC configuration for all ZSALES_* keys (single SELECT) ---
  DATA lt_tvarvc TYPE STANDARD TABLE OF tvarvc WITH EMPTY KEY.
  SELECT *
    FROM tvarvc
    INTO TABLE @lt_tvarvc
    WHERE name IN ( 'ZSALES_NONTRADEGL', 'ZSALES_NFT',      'ZSALES_LFT',
                    'ZSALES_VAT',         'ZSALES_NQVAT',    'ZSALES_EXMPVAT',
                    'ZSALES_ZEROVAT',     'ZSALES_TAXNVAT',  'ZSALES_DISCOUNT' ).

  DATA:
    lr_nontradegl TYPE ty_r_racct,
    lr_nft        TYPE ty_r_racct,
    lr_lft        TYPE ty_r_racct,
    lr_vat_gl     TYPE ty_r_racct,
    lr_discount   TYPE ty_r_racct,
    lr_nqvat      TYPE ty_r_mwskz,
    lr_exmpvat    TYPE ty_r_mwskz,
    lr_zerovat    TYPE ty_r_mwskz,
    lr_taxnvat    TYPE ty_r_mwskz.

  LOOP AT lt_tvarvc ASSIGNING FIELD-SYMBOL(<tv>).
    DATA(ls_rng) = VALUE rseloption(
      sign   = <tv>-sign
      option = <tv>-opti
      low    = <tv>-low
      high   = <tv>-high ).
    CASE <tv>-name.
      WHEN 'ZSALES_NONTRADEGL'. APPEND ls_rng TO lr_nontradegl.
      WHEN 'ZSALES_NFT'.        APPEND ls_rng TO lr_nft.
      WHEN 'ZSALES_LFT'.        APPEND ls_rng TO lr_lft.
      WHEN 'ZSALES_VAT'.        APPEND ls_rng TO lr_vat_gl.
      WHEN 'ZSALES_DISCOUNT'.   APPEND ls_rng TO lr_discount.
      WHEN 'ZSALES_NQVAT'.
        APPEND VALUE #( sign = ls_rng-sign option = ls_rng-option
                        low  = ls_rng-low  high   = ls_rng-high ) TO lr_nqvat.
      WHEN 'ZSALES_EXMPVAT'.
        APPEND VALUE #( sign = ls_rng-sign option = ls_rng-option
                        low  = ls_rng-low  high   = ls_rng-high ) TO lr_exmpvat.
      WHEN 'ZSALES_ZEROVAT'.
        APPEND VALUE #( sign = ls_rng-sign option = ls_rng-option
                        low  = ls_rng-low  high   = ls_rng-high ) TO lr_zerovat.
      WHEN 'ZSALES_TAXNVAT'.
        APPEND VALUE #( sign = ls_rng-sign option = ls_rng-option
                        low  = ls_rng-low  high   = ls_rng-high ) TO lr_taxnvat.
    ENDCASE.
  ENDLOOP.

  "--- 2. Identify qualifying documents via Non-Trade AR GL filter (FS logic) ---
  " Pass BUKRS + BUDAT + RACCT (ZSALES_NONTRADEGL) into ACDOCA-RBUKRS/BUDAT/RACCT
  DATA lt_doc_keys TYPE SORTED TABLE OF ty_acdoca
                   WITH NON-UNIQUE KEY rbukrs belnr gjahr.

  SELECT CompanyCode        AS rbukrs,
         AccountingDocument AS belnr,
         FiscalYear         AS gjahr,
         PostingDate        AS budat
    FROM I_JournalEntryItem
    INTO CORRESPONDING FIELDS OF TABLE @lt_doc_keys
    WHERE CompanyCode       = @p_bukrs
      AND FiscalYear        = @p_gjahr
      AND PostingDate       IN @s_budat
      AND GLAccount         IN @lr_nontradegl
      AND Customer          IN @s_kunnr
      AND Ledger            = '0L'
      AND DebitCreditCode   = 'S'.   " AR debit lines only

  IF sy-subrc <> 0.
    MESSAGE 'No Non-Trade sales documents found for the selection.' TYPE 'S'
            DISPLAY LIKE 'W'.
    RETURN.
  ENDIF.

  DELETE ADJACENT DUPLICATES FROM lt_doc_keys COMPARING rbukrs belnr gjahr.

  "--- 3. Fetch ALL line items for qualifying documents ---
  DATA lt_acdoca TYPE ty_acdoca_tab.

  SELECT CompanyCode                  AS rbukrs,
         AccountingDocument           AS belnr,
         FiscalYear                   AS gjahr,
         LedgerGLLineItem             AS docln,
         Customer                     AS kunnr,
         TransactionCurrency          AS waers,
         DebitCreditCode              AS drcrk,
         PostingDate                  AS budat,
         GLAccount                    AS racct,
         DocumentItemText             AS sgtxt,
         TaxCode                      AS mwskz,
         PostingKey                   AS bschl,
         ProfitCenter                 AS prctr,
         AmountInCompanyCodeCurrency  AS hsl,
         JournalEntryItemCategory     AS linetype,
         SalesOrganization            AS vkorg,
         DistributionChannel          AS vtweg,
         OrganizationDivision         AS spart
    FROM I_JournalEntryItem
    INTO CORRESPONDING FIELDS OF TABLE @lt_acdoca
    FOR ALL ENTRIES IN @lt_doc_keys
    WHERE CompanyCode        = @lt_doc_keys-rbukrs
      AND AccountingDocument = @lt_doc_keys-belnr
      AND FiscalYear         = @lt_doc_keys-gjahr
      AND Ledger             = '0L'.

  CHECK sy-subrc = 0.

  "--- 4. Fetch document headers (includes BUPLA and BLDAT) ---
  DATA lt_bkpf TYPE ty_bkpf_tab.

  SELECT CompanyCode                  AS bukrs,
         AccountingDocument           AS belnr,
         FiscalYear                   AS gjahr,
         AccountingDocumentType       AS blart,
         PostingDate                  AS budat,
         DocumentDate                 AS bldat,
         AccountingDocumentHeaderText AS bktxt,
         AlternativeReferenceDocument AS xblnr,
         BusinessPlace                AS bupla
    FROM I_JournalEntry
    INTO CORRESPONDING FIELDS OF TABLE @lt_bkpf
    FOR ALL ENTRIES IN @lt_doc_keys
    WHERE CompanyCode        = @lt_doc_keys-rbukrs
      AND AccountingDocument = @lt_doc_keys-belnr
      AND FiscalYear         = @lt_doc_keys-gjahr.

  "--- 5. GL master: P&L vs Balance Sheet (via I_GLAccount + I_CompanyCode) ---
  DATA lv_ktopl TYPE ktopl.
  SELECT SINGLE ChartOfAccounts FROM I_CompanyCode
    INTO @lv_ktopl WHERE CompanyCode = @p_bukrs.

  DATA lt_gl_master TYPE ty_gl_mst_tab.
  IF lv_ktopl IS NOT INITIAL.
    SELECT GLAccount            AS racct,
           IsBalanceSheetAccount AS xbilk
      FROM I_GLAccount
      INTO CORRESPONDING FIELDS OF TABLE @lt_gl_master
      FOR ALL ENTRIES IN @lt_acdoca
      WHERE ChartOfAccounts = @lv_ktopl
        AND GLAccount       = @lt_acdoca-racct.
  ENDIF.

  "--- 6. GL account texts ---
  DATA lt_gl_text TYPE ty_gl_txt_tab.
  SELECT GLAccount     AS racct,
         GLAccountName AS text20
    FROM I_GLAccountText
    INTO CORRESPONDING FIELDS OF TABLE @lt_gl_text
    FOR ALL ENTRIES IN @lt_acdoca
    WHERE GLAccount = @lt_acdoca-racct
      AND Language  = @sy-langu.

  "--- 7. GL classification from custom table (OVT/FCDA/etc.) ---
  DATA lt_gl_class TYPE ty_gl_cls_tab.
  SELECT gl_account, identifier
    FROM zdt_r2r_fl_gls
    INTO CORRESPONDING FIELDS OF TABLE @lt_gl_class
    FOR ALL ENTRIES IN @lt_acdoca
    WHERE gl_account = @lt_acdoca-racct.

  "--- 8. Unique customers for reference data lookups ---
  DATA lt_kunnr_keys TYPE SORTED TABLE OF ty_acdoca
                     WITH NON-UNIQUE KEY kunnr.
  lt_kunnr_keys = CORRESPONDING #( lt_acdoca ).
  DELETE lt_kunnr_keys WHERE kunnr IS INITIAL.
  DELETE ADJACENT DUPLICATES FROM lt_kunnr_keys COMPARING kunnr.

  "--- 9. TIN per customer (IS-U dfkkbptaxnum -- no standard CDS equivalent) ---
  DATA lt_tax TYPE ty_tax_tab.
  SELECT partner, taxnum
    FROM dfkkbptaxnum
    INTO CORRESPONDING FIELDS OF TABLE @lt_tax
    FOR ALL ENTRIES IN @lt_kunnr_keys
    WHERE partner = @lt_kunnr_keys-kunnr.

  "--- 10. BP address (but020 + adrc -- full subfields not exposed via CDS) ---
  DATA lt_bp_addr TYPE ty_addr_tab.
  SELECT partner, addrnumber
    FROM but020
    INTO CORRESPONDING FIELDS OF TABLE @lt_bp_addr
    FOR ALL ENTRIES IN @lt_kunnr_keys
    WHERE partner    = @lt_kunnr_keys-kunnr
      AND flgdefault = 'X'.

  DATA lt_adrc TYPE ty_adrc_tab.
  IF lt_bp_addr IS NOT INITIAL.
    SELECT addrnumber, name1, name2, name3, name4,
           street, str_suppl1, str_suppl2, str_suppl3, location, city1
      FROM adrc
      INTO CORRESPONDING FIELDS OF TABLE @lt_adrc
      FOR ALL ENTRIES IN @lt_bp_addr
      WHERE addrnumber = @lt_bp_addr-addrnumber
        AND nation     = space.
  ENDIF.

  "--- 11. Sales office ---
  DATA lt_knvv TYPE ty_knvv_tab.
  SELECT Customer            AS kunnr,
         SalesOrganization   AS vkorg,
         DistributionChannel AS vtweg,
         Division            AS spart,
         SalesOffice         AS vkbur
    FROM I_CustomerSalesArea
    INTO CORRESPONDING FIELDS OF TABLE @lt_knvv
    FOR ALL ENTRIES IN @lt_kunnr_keys
    WHERE Customer = @lt_kunnr_keys-kunnr.

  "--- 12. Process into output tables ---
  PERFORM process_data
    USING lt_acdoca lt_bkpf lt_gl_class lt_gl_master lt_gl_text
          lt_tax lt_bp_addr lt_adrc lt_knvv
          lr_nft lr_lft lr_vat_gl lr_discount
          lr_nqvat lr_exmpvat lr_zerovat lr_taxnvat.

ENDFORM.


*======================================================================*
* FORM: process_data
* Business logic: categorise amounts per document / line, build output.
* For SJ/SL: populates gt_output (one row per document).
* For DL:    populates gt_output_hdr + gt_output_itm (hierarchical ALV)
*            AND gt_output (flat rows per credit line for file download).
* Fix vs old code: amounts are fully accumulated BEFORE any row is written,
* eliminating the partial-totals bug in the former inline DL block.
*======================================================================*
FORM process_data
  USING it_acdoca    TYPE ty_acdoca_tab
        it_bkpf      TYPE ty_bkpf_tab
        it_gl_class  TYPE ty_gl_cls_tab
        it_gl_master TYPE ty_gl_mst_tab
        it_gl_text   TYPE ty_gl_txt_tab
        it_tax       TYPE ty_tax_tab
        it_bp_addr   TYPE ty_addr_tab
        it_adrc      TYPE ty_adrc_tab
        it_knvv      TYPE ty_knvv_tab
        ir_nft       TYPE ty_r_racct
        ir_lft       TYPE ty_r_racct
        ir_vat_gl    TYPE ty_r_racct
        ir_discount  TYPE ty_r_racct
        ir_nqvat     TYPE ty_r_mwskz
        ir_exmpvat   TYPE ty_r_mwskz
        ir_zerovat   TYPE ty_r_mwskz
        ir_taxnvat   TYPE ty_r_mwskz.

  " lv_seq is a monotonic counter linking hdr rows to itm rows; must not be reset per document
  DATA lv_seq TYPE i.

  " Temp table holds this document's credit lines; filled in inner loop, consumed after it
  DATA lt_cr_lines TYPE STANDARD TABLE OF ty_acdoca WITH EMPTY KEY.

  SORT it_acdoca BY rbukrs belnr gjahr.

  LOOP AT it_acdoca ASSIGNING FIELD-SYMBOL(<item>)
    GROUP BY ( rbukrs = <item>-rbukrs
               belnr  = <item>-belnr
               gjahr  = <item>-gjahr )
    ASCENDING
    ASSIGNING FIELD-SYMBOL(<grp>).

    READ TABLE it_bkpf ASSIGNING FIELD-SYMBOL(<hdr>)
      WITH KEY bukrs = <grp>-rbukrs belnr = <grp>-belnr gjahr = <grp>-gjahr
      BINARY SEARCH.
    CHECK sy-subrc = 0.

    " Resolve customer and AR GL from first matching lines in the group
    DATA: lv_kunnr    TYPE kunnr,
          lv_ar_gl    TYPE racct,
          lv_ar_gl_nm TYPE string.

    LOOP AT GROUP <grp> ASSIGNING FIELD-SYMBOL(<ln>).
      IF <ln>-kunnr IS NOT INITIAL AND lv_kunnr IS INITIAL.
        lv_kunnr = <ln>-kunnr.
      ENDIF.
      IF <ln>-drcrk = 'S' AND lv_ar_gl IS INITIAL.
        lv_ar_gl = <ln>-racct.
      ENDIF.
    ENDLOOP.

    " TIN -- keyed per customer
    DATA lv_tin TYPE string.
    READ TABLE it_tax ASSIGNING FIELD-SYMBOL(<tax>)
      WITH KEY partner = lv_kunnr BINARY SEARCH.
    IF sy-subrc = 0 AND <tax>-taxnum IS NOT INITIAL.
      lv_tin = |{ <tax>-taxnum+0(3) }-{ <tax>-taxnum+3(3) }-{ <tax>-taxnum+6(3) }-{ <tax>-taxnum+9 }|.
    ENDIF.

    " Address
    DATA: lv_name  TYPE string,
          lv_addr1 TYPE string,
          lv_addr2 TYPE string.
    READ TABLE it_bp_addr ASSIGNING FIELD-SYMBOL(<baddr>)
      WITH KEY partner = lv_kunnr BINARY SEARCH.
    IF sy-subrc = 0.
      READ TABLE it_adrc ASSIGNING FIELD-SYMBOL(<adr>)
        WITH KEY addrnumber = <baddr>-addrnumber BINARY SEARCH.
      IF sy-subrc = 0.
        lv_name  = condense( |{ <adr>-name1 } { <adr>-name2 } { <adr>-name3 } { <adr>-name4 }| ).
        lv_addr1 = condense( |{ <adr>-street }, { <adr>-str_suppl1 }, { <adr>-str_suppl2 }| ).
        " Assumption C: Address 2 populated when address 1 characters are exceeded
        lv_addr2 = condense( |{ <adr>-str_suppl3 } { <adr>-location } { <adr>-city1 }| ).
      ENDIF.
    ENDIF.

    " Sales office
    DATA lv_vkbur TYPE vkbur.
    LOOP AT GROUP <grp> ASSIGNING FIELD-SYMBOL(<sl>).
      IF <sl>-vkorg IS NOT INITIAL AND lv_vkbur IS INITIAL.
        READ TABLE it_knvv ASSIGNING FIELD-SYMBOL(<kv>)
          WITH KEY kunnr = lv_kunnr vkorg = <sl>-vkorg
                   vtweg = <sl>-vtweg spart = <sl>-spart
          BINARY SEARCH.
        IF sy-subrc = 0. lv_vkbur = <kv>-vkbur. ENDIF.
      ENDIF.
    ENDLOOP.

    " AR GL text
    READ TABLE it_gl_text ASSIGNING FIELD-SYMBOL(<art>)
      WITH KEY racct = lv_ar_gl BINARY SEARCH.
    IF sy-subrc = 0. lv_ar_gl_nm = <art>-text20. ENDIF.

    "==========================================================
    " INNER LOOP: accumulate amounts; collect credit lines
    "==========================================================
    DATA:
      lv_total_amt   TYPE wrbtr,
      lv_non_rev     TYPE wrbtr,
      lv_revenue     TYPE wrbtr,
      lv_nft         TYPE wrbtr,
      lv_lft         TYPE wrbtr,
      lv_vat_amt     TYPE wrbtr,
      lv_discount    TYPE wrbtr,
      lv_notq_vat    TYPE wrbtr,
      lv_exempt      TYPE wrbtr,
      lv_zero_rated  TYPE wrbtr,
      lv_taxable_net TYPE wrbtr,
      lv_output_vat  TYPE wrbtr,
      lv_bschl       TYPE bschl,
      lv_mwskz       TYPE mwskz,
      lv_prctr       TYPE prctr,
      lv_sgtxt       TYPE string.

    CLEAR lt_cr_lines.

    LOOP AT GROUP <grp> ASSIGNING FIELD-SYMBOL(<li>).

      IF <li>-linetype = '02000' AND lv_sgtxt IS INITIAL.
        lv_sgtxt = <li>-sgtxt.
      ENDIF.
      IF <li>-bschl IS NOT INITIAL. lv_bschl = <li>-bschl. ENDIF.
      IF <li>-mwskz IS NOT INITIAL. lv_mwskz = <li>-mwskz. ENDIF.
      IF <li>-prctr IS NOT INITIAL. lv_prctr = <li>-prctr. ENDIF.

      IF <li>-drcrk = 'S'.   "--- DEBIT (AR) side ---
        lv_total_amt = lv_total_amt + <li>-hsl.

        IF <li>-mwskz IN ir_nqvat.
          lv_notq_vat    = lv_notq_vat    + <li>-hsl.
        ELSEIF <li>-mwskz IN ir_exmpvat.
          lv_exempt      = lv_exempt      + <li>-hsl.
        ELSEIF <li>-mwskz IN ir_zerovat.
          lv_zero_rated  = lv_zero_rated  + <li>-hsl.
        ELSEIF <li>-mwskz IN ir_taxnvat.
          lv_taxable_net = lv_taxable_net + <li>-hsl.
        ENDIF.

      ELSEIF <li>-drcrk = 'H'.   "--- CREDIT side ---
        IF <li>-racct IN ir_nft.
          lv_nft      = lv_nft      + <li>-hsl.
        ELSEIF <li>-racct IN ir_lft.
          lv_lft      = lv_lft      + <li>-hsl.
        ELSEIF <li>-racct IN ir_vat_gl.
          lv_vat_amt  = lv_vat_amt  + <li>-hsl.
        ELSEIF <li>-racct IN ir_discount.
          lv_discount = lv_discount + <li>-hsl.
        ELSE.
          READ TABLE it_gl_class ASSIGNING FIELD-SYMBOL(<glc>)
            WITH KEY gl_account = <li>-racct BINARY SEARCH.
          IF sy-subrc = 0 AND <glc>-identifier = 'OVT'.
            lv_output_vat = lv_output_vat + <li>-hsl.
          ELSE.
            READ TABLE it_gl_master ASSIGNING FIELD-SYMBOL(<glm>)
              WITH KEY racct = <li>-racct BINARY SEARCH.
            IF sy-subrc = 0 AND <glm>-xbilk = abap_false.
              lv_revenue = lv_revenue + <li>-hsl.
            ELSE.
              lv_non_rev = lv_non_rev + <li>-hsl.
            ENDIF.
          ENDIF.
        ENDIF.

        " Collect credit line for post-loop DL processing
        APPEND <li> TO lt_cr_lines.

      ENDIF.

    ENDLOOP.   " end inner loop (lines within document)

    "==========================================================
    " POST-LOOP: all amounts are now final. Build output rows.
    "==========================================================
    ADD 1 TO lv_seq.

    DATA lv_total_sales TYPE wrbtr.
    DATA lv_gross_tax   TYPE wrbtr.
    lv_total_sales = lv_exempt + lv_zero_rated + lv_taxable_net.
    lv_gross_tax   = lv_total_sales + lv_output_vat.

    DATA lv_inv_no     TYPE xblnr1.
    DATA lv_dm_no      TYPE string.
    IF <hdr>-blart <> 'DF'.
      lv_inv_no = <hdr>-xblnr.
    ELSE.
      lv_dm_no = <hdr>-xblnr.
    ENDIF.

    DATA lv_budat_fmt   TYPE string.
    DATA lv_bldat_fmt   TYPE string.
    DATA lv_bill_period TYPE string.
    lv_budat_fmt   = |{ <hdr>-budat+4(2) }/{ <hdr>-budat+6(2) }/{ <hdr>-budat+0(4) }|.
    lv_bldat_fmt   = |{ <hdr>-bldat+4(2) }/{ <hdr>-bldat+6(2) }/{ <hdr>-bldat+0(4) }|.
    lv_bill_period = <hdr>-budat+4(2).

    IF gv_mode = gc_dl.

      " --- Hierarchical header row (one per document) ---
      DATA ls_hdr TYPE ty_output_hdr.
      ls_hdr = VALUE ty_output_hdr(
        seq_no        = lv_seq
        budat         = lv_budat_fmt
        inv_dm_date   = lv_bldat_fmt
        belnr         = <hdr>-belnr
        document_type = <hdr>-blart
        invoice_no    = lv_inv_no
        dm_no         = lv_dm_no
        bill_period   = lv_bill_period
        bp_code       = lv_kunnr
        tin           = lv_tin
        reg_name      = lv_name
        address1      = lv_addr1
        address2      = lv_addr2
        bukrs         = <hdr>-bukrs
        bupla         = <hdr>-bupla
        sales_office  = lv_vkbur
        prctr         = lv_prctr
        bktxt         = <hdr>-bktxt
        reference     = lv_sgtxt
        total_amt     = lv_total_amt
        non_revenue   = lv_non_rev
        revenue       = lv_revenue
        nft           = lv_nft
        lft           = lv_lft
        vat_amt       = lv_vat_amt
        discount      = lv_discount
        notq_vat      = lv_notq_vat
        exempt        = lv_exempt
        zero_rated    = lv_zero_rated
        taxable_net   = lv_taxable_net
        output_vat    = lv_output_vat
        total_sales   = lv_total_sales
        gross_tax     = lv_gross_tax ).
      APPEND ls_hdr TO gt_output_hdr.

      " --- Per credit line: hierarchical item row + flat row for file download ---
      DATA: lv_cr_name TYPE string,
            lv_gl_cat  TYPE char20,
            ls_itm     TYPE ty_output_itm,
            ls_dl      TYPE ty_output.

      LOOP AT lt_cr_lines ASSIGNING FIELD-SYMBOL(<cr>).

        CLEAR: lv_cr_name, lv_gl_cat.

        " GL text for this credit line
        READ TABLE it_gl_text ASSIGNING FIELD-SYMBOL(<crt>)
          WITH KEY racct = <cr>-racct BINARY SEARCH.
        IF sy-subrc = 0. lv_cr_name = <crt>-text20. ENDIF.

        " GL category label (same priority as amount categorisation above)
        IF <cr>-racct IN ir_nft.
          lv_gl_cat = 'NFT'.
        ELSEIF <cr>-racct IN ir_lft.
          lv_gl_cat = 'LFT'.
        ELSEIF <cr>-racct IN ir_vat_gl.
          lv_gl_cat = 'VAT'.
        ELSEIF <cr>-racct IN ir_discount.
          lv_gl_cat = 'Discount'.
        ELSE.
          READ TABLE it_gl_class ASSIGNING FIELD-SYMBOL(<glc2>)
            WITH KEY gl_account = <cr>-racct BINARY SEARCH.
          IF sy-subrc = 0 AND <glc2>-identifier = 'OVT'.
            lv_gl_cat = 'Output VAT'.
          ELSE.
            READ TABLE it_gl_master ASSIGNING FIELD-SYMBOL(<glm2>)
              WITH KEY racct = <cr>-racct BINARY SEARCH.
            IF sy-subrc = 0 AND <glm2>-xbilk = abap_false.
              lv_gl_cat = 'Revenue'.
            ELSE.
              lv_gl_cat = 'Non-Revenue'.
            ENDIF.
          ENDIF.
        ENDIF.

        " Hierarchical item (child of header via seq_no binding)
        ls_itm = VALUE ty_output_itm(
          seq_no      = lv_seq
          docln       = <cr>-docln
          posting_key = <cr>-bschl
          vat_code    = <cr>-mwskz
          wht_code    = space
          ar_gl_no    = lv_ar_gl
          ar_gl_name  = lv_ar_gl_nm
          cr_gl_no    = <cr>-racct
          cr_gl_name  = lv_cr_name
          prctr       = <cr>-prctr
          gl_category = lv_gl_cat
          line_amount = <cr>-hsl ).
        APPEND ls_itm TO gt_output_itm.

        " Flat row -- document totals repeated per credit line (for .dat/.csv/.xls export)
        ls_dl = VALUE ty_output(
          budat         = lv_budat_fmt
          tin           = lv_tin
          reg_name      = lv_name
          address1      = lv_addr1
          address2      = lv_addr2
          belnr         = <hdr>-belnr
          document_type = <hdr>-blart
          bupla         = <hdr>-bupla
          prctr         = <cr>-prctr
          sales_office  = lv_vkbur
          bp_code       = lv_kunnr
          bukrs         = <hdr>-bukrs
          bktxt         = <hdr>-bktxt
          reference     = lv_sgtxt
          inv_dm_date   = lv_bldat_fmt
          bill_period   = lv_bill_period
          posting_key   = <cr>-bschl
          vat_code      = <cr>-mwskz
          wht_code      = space
          ar_gl_no      = lv_ar_gl
          ar_gl_name    = lv_ar_gl_nm
          cr_gl_no      = <cr>-racct
          cr_gl_name    = lv_cr_name
          total_amt     = lv_total_amt
          non_revenue   = lv_non_rev
          revenue       = lv_revenue
          nft           = lv_nft
          lft           = lv_lft
          vat_amt       = lv_vat_amt
          discount      = lv_discount
          notq_vat      = lv_notq_vat
          exempt        = lv_exempt
          zero_rated    = lv_zero_rated
          taxable_net   = lv_taxable_net
          output_vat    = lv_output_vat
          total_sales   = lv_total_sales
          gross_tax     = lv_gross_tax
          invoice_no    = lv_inv_no
