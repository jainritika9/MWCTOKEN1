*======================================================================*
* FORM: get_filedata
* Builds gt_out_tab (string table) for file download.
* Always uses gt_output (flat table) regardless of mode.
* For DL mode gt_output contains one row per credit GL line.
*======================================================================*
FORM get_filedata.
  CLEAR gt_out_tab.

  " Report title
  DATA lv_title TYPE string.
  CASE gv_mode.
    WHEN gc_sj. lv_title = TEXT-007.
    WHEN gc_sl. lv_title = TEXT-008.
    WHEN gc_dl. lv_title = TEXT-009.
  ENDCASE.
  APPEND lv_title TO gt_out_tab.

  " Header block from shared display class (populated for SJ/SL; may be empty for DL)
  LOOP AT gt_creaflow INTO DATA(ls_cf).
    APPEND ls_cf-string TO gt_out_tab.
  ENDLOOP.

  " Blank separator line
  APPEND space TO gt_out_tab.

  " Data rows converted to text
  DATA lt_temp TYPE truxs_t_text_data.
  CALL FUNCTION 'SAP_CONVERT_TO_TEX_FORMAT'
    EXPORTING  i_field_seperator    = cl_abap_char_utilities=>horizontal_tab
    TABLES     i_tab_sap_data       = gt_output
    CHANGING   i_tab_converted_data = lt_temp
    EXCEPTIONS conversion_failed    = 1
               OTHERS               = 2.
  IF sy-subrc = 0.
    APPEND LINES OF lt_temp TO gt_out_tab.
  ENDIF.

ENDFORM.


*======================================================================*
* FORM: write_log
* Inserts one execution record into ZAB_R2R_SALES_LOG.
* Create table ZAB_R2R_SALES_LOG in SE11 using fields from ty_log.
* Suggested key: MANDT + BUKRS + CPUDT + CPUTM + USNAM.
*======================================================================*
FORM write_log USING iv_output_option TYPE char5.
  DATA ls_log TYPE ty_log.
  ls_log-mandt         = sy-mandt.
  ls_log-bukrs         = p_bukrs.
  ls_log-budat_from    = s_budat-low.
  ls_log-budat_to      = s_budat-high.
  ls_log-gjahr         = p_gjahr.
  ls_log-kunnr         = s_kunnr-low.
  ls_log-output_option = iv_output_option.
  ls_log-usnam         = sy-uname.
  ls_log-cpudt         = sy-datum.
  ls_log-cputm         = sy-uzeit.

  INSERT zab_r2r_sales_log FROM ls_log.
  IF sy-subrc <> 0.
    MESSAGE 'Execution log could not be saved.' TYPE 'W'.
  ENDIF.
ENDFORM.


