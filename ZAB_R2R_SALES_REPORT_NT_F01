*======================================================================*
* FORM: set_alv_columns
* Controls column labels and visibility for flat ALV (SJ / SL modes).
*======================================================================*
FORM set_alv_columns USING io_cols TYPE REF TO cl_salv_columns_table.

  " First hide all columns
  DATA(lt_all) = io_cols->get( ).
  LOOP AT lt_all ASSIGNING FIELD-SYMBOL(<ce>).
    TRY.
        io_cols->get_column( <ce>-columnname )->set_visible( abap_false ).
      CATCH cx_salv_not_found.                              "#EC NEEDED
    ENDTRY.
  ENDLOOP.

  " Columns always shown regardless of mode
  DATA lt_always TYPE STANDARD TABLE OF string WITH EMPTY KEY.
  lt_always = VALUE #( ( `BUDAT` ) ( `TIN` ) ( `REG_NAME` )
                       ( `ADDRESS1` ) ( `ADDRESS2` ) ).

  " Sales Journal columns (columns C-S per FS)
  DATA lt_sj TYPE STANDARD TABLE OF string WITH EMPTY KEY.
  lt_sj = VALUE #(
    ( `TOTAL_AMT` ) ( `NON_REVENUE` ) ( `REVENUE` )
    ( `NFT` ) ( `LFT` ) ( `VAT_AMT` ) ( `DISCOUNT` )
    ( `BKTXT` ) ( `REFERENCE` ) ( `BELNR` )
    ( `INVOICE_NO` ) ( `DM_NO` ) ).

  " Summary List columns (columns T-AA per FS)
  DATA lt_sl TYPE STANDARD TABLE OF string WITH EMPTY KEY.
  lt_sl = VALUE #(
    ( `NOTQ_VAT` ) ( `EXEMPT` ) ( `ZERO_RATED` ) ( `TAXABLE_NET` )
    ( `OUTPUT_VAT` ) ( `TOTAL_SALES` ) ( `GROSS_TAX` ) ).

  DATA lt_visible TYPE STANDARD TABLE OF lvc_fname WITH EMPTY KEY.
  lt_visible = lt_always.
  CASE gv_mode.
    WHEN gc_sj. APPEND LINES OF lt_sj TO lt_visible.
    WHEN gc_sl. APPEND LINES OF lt_sl TO lt_visible.
  ENDCASE.

  LOOP AT lt_visible INTO DATA(lv_fn).
    TRY.
        io_cols->get_column( lv_fn )->set_visible( abap_true ).
      CATCH cx_salv_not_found.                              "#EC NEEDED
    ENDTRY.
  ENDLOOP.

  " Apply column header texts
  DATA lt_labels TYPE STANDARD TABLE OF ty_fieldcat WITH EMPTY KEY.
  lt_labels = VALUE #(
    ( fieldname = 'BUDAT'        coltext_l = 'Posting Date'             coltext_m = 'Post Date'   coltext_s = 'PstDt' )
    ( fieldname = 'TIN'          coltext_l = 'TIN'                      coltext_m = 'TIN'         coltext_s = 'TIN'   )
    ( fieldname = 'REG_NAME'     coltext_l = 'Registered Name'          coltext_m = 'Reg.Name'    coltext_s = 'RegNm' )
    ( fieldname = 'ADDRESS1'     coltext_l = 'Address'                  coltext_m = 'Address'     coltext_s = 'Addr1' )
    ( fieldname = 'ADDRESS2'     coltext_l = 'Address 2'                coltext_m = 'Address 2'   coltext_s = 'Addr2' )
    ( fieldname = 'TOTAL_AMT'    coltext_l = 'Total Amount'             coltext_m = 'Total Amt'   coltext_s = 'TotAm' )
    ( fieldname = 'NON_REVENUE'  coltext_l = 'Non-Revenue'              coltext_m = 'Non-Rev'     coltext_s = 'NRev'  )
    ( fieldname = 'REVENUE'      coltext_l = 'Revenue'                  coltext_m = 'Revenue'     coltext_s = 'Rev'   )
    ( fieldname = 'NFT'          coltext_l = 'NFT'                      coltext_m = 'NFT'         coltext_s = 'NFT'   )
    ( fieldname = 'LFT'          coltext_l = 'LFT'                      coltext_m = 'LFT'         coltext_s = 'LFT'   )
    ( fieldname = 'VAT_AMT'      coltext_l = 'VAT'                      coltext_m = 'VAT'         coltext_s = 'VAT'   )
    ( fieldname = 'DISCOUNT'     coltext_l = 'Discount'                 coltext_m = 'Discount'    coltext_s = 'Disc'  )
    ( fieldname = 'BKTXT'        coltext_l = 'Header Text'              coltext_m = 'Hdr Text'    coltext_s = 'HdrTx' )
    ( fieldname = 'REFERENCE'    coltext_l = 'Reference'                coltext_m = 'Reference'   coltext_s = 'Ref'   )
    ( fieldname = 'BELNR'        coltext_l = 'Document Number'          coltext_m = 'Doc No'      coltext_s = 'DocNo' )
    ( fieldname = 'INVOICE_NO'   coltext_l = 'Invoice Number'           coltext_m = 'Invoice No'  coltext_s = 'InvNo' )
    ( fieldname = 'DM_NO'        coltext_l = 'Debit Memo Number'        coltext_m = 'DM No'       coltext_s = 'DMNo'  )
    ( fieldname = 'NOTQ_VAT'     coltext_l = 'Not Qualified Output VAT' coltext_m = 'NotQual VAT' coltext_s = 'NQVat' )
    ( fieldname = 'EXEMPT'       coltext_l = 'Exempt'                   coltext_m = 'Exempt'      coltext_s = 'Exmpt' )
    ( fieldname = 'ZERO_RATED'   coltext_l = 'Zero-Rated'               coltext_m = 'Zero-Rated'  coltext_s = 'ZroRt' )
    ( fieldname = 'TAXABLE_NET'  coltext_l = 'Taxable Net of VAT'       coltext_m = 'Tax Net VAT' coltext_s = 'TxNet' )
    ( fieldname = 'OUTPUT_VAT'   coltext_l = 'Output VAT'               coltext_m = 'Output VAT'  coltext_s = 'OutVT' )
    ( fieldname = 'TOTAL_SALES'  coltext_l = 'Total Sales'              coltext_m = 'Total Sales' coltext_s = 'TotSl' )
    ( fieldname = 'GROSS_TAX'    coltext_l = 'Gross Taxable'            coltext_m = 'Gross Tax'   coltext_s = 'GrsTx' ) ).

  LOOP AT lt_labels INTO DATA(ls_lbl).
    TRY.
        DATA(lo_c) = io_cols->get_column( ls_lbl-fieldname ).
        lo_c->set_long_text(   ls_lbl-coltext_l ).
        lo_c->set_medium_text( ls_lbl-coltext_m ).
        lo_c->set_short_text(  ls_lbl-coltext_s ).
      CATCH cx_salv_not_found.                              "#EC NEEDED
    ENDTRY.
  ENDLOOP.

ENDFORM.
*======================================================================*
* FORM: get_filedata
* Builds gt_out_tab (string table) for file download.
* Always uses gt_output (flat table) regardless of mode.
* For DL mode gt_output contains one row per credit GL line.
*======================================================================*
FORM get_filedata.
  CLEAR gt_out_tab.

  " Report title
  DATA lv_title TYPE string.
  CASE gv_mode.
    WHEN gc_sj. lv_title = TEXT-007.
    WHEN gc_sl. lv_title = TEXT-008.
    WHEN gc_dl. lv_title = TEXT-009.
  ENDCASE.
  APPEND lv_title TO gt_out_tab.

  " Header block from shared display class (populated for SJ/SL; may be empty for DL)
  LOOP AT gt_creaflow INTO DATA(ls_cf).
    APPEND ls_cf-string TO gt_out_tab.
  ENDLOOP.

  " Blank separator line
  APPEND space TO gt_out_tab.

  " Data rows converted to text
  DATA lt_temp TYPE truxs_t_text_data.
  CALL FUNCTION 'SAP_CONVERT_TO_TEX_FORMAT'
    EXPORTING
      i_field_seperator    = cl_abap_char_utilities=>horizontal_tab
    TABLES
      i_tab_sap_data       = gt_output
    CHANGING
      i_tab_converted_data = lt_temp
    EXCEPTIONS
      conversion_failed    = 1
      OTHERS               = 2.
  IF sy-subrc = 0.
    APPEND LINES OF lt_temp TO gt_out_tab.
  ENDIF.

ENDFORM.


