    ( fieldname = 'LFT'          coltext_l = 'LFT'                      coltext_m = 'LFT'         coltext_s = 'LFT'   )
    ( fieldname = 'VAT_AMT'      coltext_l = 'VAT'                      coltext_m = 'VAT'         coltext_s = 'VAT'   )
    ( fieldname = 'DISCOUNT'     coltext_l = 'Discount'                 coltext_m = 'Discount'    coltext_s = 'Disc'  )
    ( fieldname = 'BKTXT'        coltext_l = 'Header Text'              coltext_m = 'Hdr Text'    coltext_s = 'HdrTx' )
    ( fieldname = 'REFERENCE'    coltext_l = 'Reference'                coltext_m = 'Reference'   coltext_s = 'Ref'   )
