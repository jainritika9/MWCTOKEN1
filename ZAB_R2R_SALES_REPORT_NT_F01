  lt_labels = VALUE #(
    ( fieldname = 'BUDAT'        coltext_l = 'Posting Date'             coltext_m = 'Post Date'   coltext_s = 'PstDt' )
    ( fieldname = 'TIN'          coltext_l = 'TIN'                      coltext_m = 'TIN'         coltext_s = 'TIN'   )
    ( fieldname = 'REG_NAME'     coltext_l = 'Registered Name'          coltext_m = 'Reg.Name'    coltext_s = 'RegNm' )
    ( fieldname = 'ADDRESS1'     coltext_l = 'Address'                  coltext_m = 'Address'     coltext_s = 'Addr1' )
    ( fieldname = 'ADDRESS2'     coltext_l = 'Address 2'                coltext_m = 'Address 2'   coltext_s = 'Addr2' )
