FORM top_of_page.
  DATA:
    lo_alv    TYPE REF TO cl_salv_table,
    lv_title  TYPE string,
    lt_header TYPE slis_t_listheader,
    ls_header TYPE slis_listheader.

  DATA lt_budat LIKE s_budat[].
  lt_budat = s_budat[].

  lv_title = TEXT-008.

  "ALV Top of the page derivation
  cl_salv_table=>factory(
        IMPORTING r_salv_table = lo_alv
        CHANGING  t_table      = gt_output ).

  CALL METHOD zcl_s2p_display=>set_top_of_page
    EXPORTING
      ip_report_title = lv_title
      ip_bukrs        = p_bukrs
      it_budat        = lt_budat
    CHANGING
      co_alv          = lo_alv.

  gt_creaflow = zcl_s2p_display=>gt_creaflow.

  LOOP AT gt_creaflow INTO DATA(gs_creaflow).
    IF sy-tabix = 1.
      " Header type 'H' (Header)
      ls_header-typ  = 'H'.
      ls_header-info = lv_title.
      APPEND ls_header TO lt_header.
    ELSEIF sy-tabix = 2.
      ls_header-typ  = 'H'.
      ls_header-info = ''.
      APPEND ls_header TO lt_header.
    ELSE.
      " Header type 'S' (Selection / Key-Value)
      SPLIT gs_creaflow-string AT ':' INTO DATA(ls_val) DATA(ls_val1).
      ls_header-typ  = 'H'.
      ls_header-info = |{ ls_val }: { ls_val1 }|.
      APPEND ls_header TO lt_header.
    ENDIF.
  ENDLOOP.

  CALL FUNCTION 'REUSE_ALV_COMMENTARY_WRITE'
    EXPORTING
      it_list_commentary = lt_header.
ENDFORM.

FORM set_pf_status USING rt_extab TYPE slis_t_extab.
  SET PF-STATUS 'ZSTATUS' EXCLUDING rt_extab.
ENDFORM.
