      APPEND ls_sum TO gt_output.

    ENDIF.

    CLEAR: lv_kunnr, lv_ar_gl, lv_ar_gl_nm, lv_tin, lv_name,
           lv_addr1, lv_addr2, lv_vkbur, lv_sgtxt, lv_bschl,
