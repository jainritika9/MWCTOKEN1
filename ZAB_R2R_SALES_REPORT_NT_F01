    ( fieldname = 'NON_REVENUE'  seltext_l = 'Non-Revenue'              seltext_m = 'Non-Rev'     seltext_s = 'NRev'  tabname = 'Head')
    ( fieldname = 'REVENUE'      seltext_l = 'Revenue'                  seltext_m = 'Revenue'     seltext_s = 'Rev'   tabname = 'Head')
    ( fieldname = 'NFT'          seltext_l = 'NFT'                      seltext_m = 'NFT'         seltext_s = 'NFT'   tabname = 'Head')
    ( fieldname = 'LFT'          seltext_l = 'LFT'                      seltext_m = 'LFT'         seltext_s = 'LFT'   tabname = 'Head')
    ( fieldname = 'VAT_AMT'      seltext_l = 'VAT'                      seltext_m = 'VAT'         seltext_s = 'VAT'   tabname = 'Head')
    ( fieldname = 'DISCOUNT'     seltext_l = 'Discount'                 seltext_m = 'Discount'    seltext_s = 'Disc'  tabname = 'Head')
    ( fieldname = 'BKTXT'        seltext_l = 'Header Text'              seltext_m = 'Hdr Text'    seltext_s = 'HdrTx' tabname = 'Head')
    ( fieldname = 'REFERENCE'    seltext_l = 'Reference'                seltext_m = 'Reference'   seltext_s = 'Ref'   tabname = 'Head')
    ( fieldname = 'BELNR'        seltext_l = 'Document Number'          seltext_m = 'Doc No'      seltext_s = 'DocNo' tabname = 'Head')
