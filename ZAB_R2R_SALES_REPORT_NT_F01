           lv_bill_period, lv_total_sales, lv_gross_tax,
           ls_hdr, ls_itm, ls_dl, lt_cr_lines.

  ENDLOOP.   " end GROUP BY document

ENDFORM.


*======================================================================*
* FORM: display_alv
* Dispatcher: routes to flat ALV (SJ/SL) or hierarchical ALV (DL).
*======================================================================*
FORM display_alv.
  IF gv_mode = gc_dl.
    PERFORM display_hier_alv.
  ELSE.
    PERFORM display_flat_alv.
  ENDIF.
ENDFORM.


*======================================================================*
* FORM: display_flat_alv
* CL_SALV_TABLE for Sales Journal and Summary List modes.
*======================================================================*
FORM display_flat_alv.

  DATA: lo_alv     TYPE REF TO cl_salv_table,
        lo_cols    TYPE REF TO cl_salv_columns_table,
        lo_events  TYPE REF TO cl_salv_events_table,
        lo_handler TYPE REF TO lcl_events,
        lv_title   TYPE string.

  CASE gv_mode.
    WHEN gc_sj. lv_title = TEXT-007.   " 'SALES REPORT - NON-TRADE (SALES JOURNAL)'
    WHEN gc_sl. lv_title = TEXT-008.   " 'SALES REPORT - NON-TRADE (SUMMARY LIST)'
  ENDCASE.

  TRY.
      cl_salv_table=>factory(
        IMPORTING r_salv_table = lo_alv
        CHANGING  t_table      = gt_output ).

      lo_cols = lo_alv->get_columns( ).
      lo_cols->set_optimize( abap_true ).

      PERFORM set_alv_columns USING lo_cols.

      lo_alv->set_screen_status(
        report        = sy-repid
        pfstatus      = 'ZSTATUS'
        set_functions = lo_alv->c_functions_all ).

      lo_events = lo_alv->get_event( ).
      CREATE OBJECT lo_handler.
      SET HANDLER lo_handler->on_added_function FOR lo_events.

      DATA lt_budat LIKE s_budat[].
      lt_budat = s_budat[].
      CALL METHOD zcl_s2p_display=>set_top_of_page
        EXPORTING ip_report_title = lv_title
                  ip_bukrs        = p_bukrs
                  it_budat        = lt_budat
        CHANGING  co_alv          = lo_alv.

      gt_creaflow = zcl_s2p_display=>gt_creaflow.

      lo_alv->display( ).

    CATCH cx_salv_msg INTO DATA(lx).
      MESSAGE lx->get_text( ) TYPE 'E'.
  ENDTRY.

ENDFORM.


*======================================================================*
* FORM: display_hier_alv
* CL_SALV_HIERSEQ_TABLE for Detailed List mode.
* Header level : one row per accounting document (gt_output_hdr).
* Item level   : one row per credit GL line     (gt_output_itm).
* Binding key  : SEQ_NO (synthetic integer, set in process_data).
*======================================================================*
FORM display_hier_alv.

  DATA: lo_hierseq  TYPE REF TO cl_salv_hierseq_table,
        lo_handler  TYPE REF TO lcl_events,
        lo_bindings TYPE REF TO cl_salv_hierseq_bindings,
        lo_hdr_cols TYPE REF TO cl_salv_columns,
        lo_itm_cols TYPE REF TO cl_salv_columns,
        lo_events   TYPE REF TO cl_salv_events_hierseq.

  TRY.
      cl_salv_hierseq_table=>create(
        IMPORTING r_hierseq       = lo_hierseq
        CHANGING  t_outtab_header = gt_output_hdr
                  t_outtab_item   = gt_output_itm ).

      " Bind header.SEQ_NO → item.SEQ_NO
      lo_bindings = lo_hierseq->get_bindings( ).
      lo_bindings->add_binding( master = 'SEQ_NO' slave = 'SEQ_NO' ).

      " Column visibility for header and item levels
      lo_hdr_cols = lo_hierseq->get_columns_header( ).
      PERFORM set_hier_hdr_columns USING lo_hdr_cols.

      lo_itm_cols = lo_hierseq->get_columns_item( ).
      PERFORM set_hier_itm_columns USING lo_itm_cols.

      " Custom PF status and event handler (same ZSTATUS as flat ALV)
      lo_hierseq->set_screen_status(
        report        = sy-repid
        pfstatus      = 'ZSTATUS'
        set_functions = lo_hierseq->c_functions_all ).

      lo_events = lo_hierseq->get_event( ).
      CREATE OBJECT lo_handler.
      SET HANDLER lo_handler->on_added_function_hier FOR lo_events.

      lo_hierseq->display( ).

    CATCH cx_salv_msg INTO DATA(lx).
      MESSAGE lx->get_text( ) TYPE 'E'.
  ENDTRY.

ENDFORM.


*======================================================================*
* FORM: set_alv_columns
* Controls column labels and visibility for flat ALV (SJ / SL modes).
*======================================================================*
FORM set_alv_columns USING io_cols TYPE REF TO cl_salv_columns_table.

  " First hide all columns
  DATA(lt_all) = io_cols->get( ).
  LOOP AT lt_all ASSIGNING FIELD-SYMBOL(<ce>).
    TRY.
        io_cols->get_column( <ce>-columnname )->set_visible( abap_false ).
      CATCH cx_salv_not_found. "#EC NEEDED
    ENDTRY.
  ENDLOOP.

  " Columns always shown regardless of mode
  DATA lt_always TYPE STANDARD TABLE OF string WITH EMPTY KEY.
  lt_always = VALUE #( ( `BUDAT` ) ( `TIN` ) ( `REG_NAME` )
                       ( `ADDRESS1` ) ( `ADDRESS2` ) ).

  " Sales Journal columns (columns C-S per FS)
  DATA lt_sj TYPE STANDARD TABLE OF string WITH EMPTY KEY.
  lt_sj = VALUE #(
    ( `TOTAL_AMT` ) ( `NON_REVENUE` ) ( `REVENUE` )
    ( `NFT` ) ( `LFT` ) ( `VAT_AMT` ) ( `DISCOUNT` )
    ( `BKTXT` ) ( `REFERENCE` ) ( `BELNR` )
    ( `INVOICE_NO` ) ( `DM_NO` ) ).

  " Summary List columns (columns T-AA per FS)
  DATA lt_sl TYPE STANDARD TABLE OF string WITH EMPTY KEY.
  lt_sl = VALUE #(
    ( `NOTQ_VAT` ) ( `EXEMPT` ) ( `ZERO_RATED` ) ( `TAXABLE_NET` )
    ( `OUTPUT_VAT` ) ( `TOTAL_SALES` ) ( `GROSS_TAX` ) ).

  DATA lt_visible TYPE STANDARD TABLE OF string WITH EMPTY KEY.
  lt_visible = lt_always.
  CASE gv_mode.
    WHEN gc_sj. APPEND LINES OF lt_sj TO lt_visible.
    WHEN gc_sl. APPEND LINES OF lt_sl TO lt_visible.
  ENDCASE.

  LOOP AT lt_visible INTO DATA(lv_fn).
    TRY.
        io_cols->get_column( lv_fn )->set_visible( abap_true ).
      CATCH cx_salv_not_found. "#EC NEEDED
    ENDTRY.
  ENDLOOP.

  " Apply column header texts
