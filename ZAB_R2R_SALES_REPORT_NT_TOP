*&---------------------------------------------------------------------*
*& Include ZAB_R2R_SALES_REPORT_NT_TOP
*&---------------------------------------------------------------------*

"--- Report output mode constants ---
CONSTANTS:
  gc_sj TYPE char2 VALUE 'SJ',   " Sales Journal
  gc_sl TYPE char2 VALUE 'SL',   " Summary List
  gc_dl TYPE char2 VALUE 'DL'.   " Detailed List

"--- Type definitions ---
TYPES:
  " Journal entry header (from I_JournalEntry)
  BEGIN OF ty_bkpf,
    bukrs TYPE bukrs,
    belnr TYPE belnr_d,
    gjahr TYPE gjahr,
    blart TYPE blart,
    budat TYPE budat,
    bldat TYPE budat,
    bktxt TYPE bktxt,
    xblnr TYPE xblnr1,
    bupla TYPE bupla,
  END OF ty_bkpf,

  " Journal entry line item (from I_JournalEntryItem)
  BEGIN OF ty_acdoca,
    rbukrs   TYPE bukrs,
    belnr    TYPE belnr_d,
    gjahr    TYPE gjahr,
    docln    TYPE char6,
    kunnr    TYPE kunnr,
    waers    TYPE waers,
    drcrk    TYPE shkzg,
    budat    TYPE budat,
    racct    TYPE racct,
    sgtxt    TYPE sgtxt,
    mwskz    TYPE mwskz,
    bschl    TYPE bschl,
    prctr    TYPE prctr,
    hsl      TYPE wrbtr,
    linetype TYPE char5,
    vkorg    TYPE vkorg,
    vtweg    TYPE vtweg,
    spart    TYPE spart,
  END OF ty_acdoca,

  " GL account balance sheet indicator (from I_GLAccount)
  BEGIN OF ty_gl_master,
    racct TYPE racct,
    xbilk TYPE xbilk,   " X = balance sheet, ' ' = P&L
  END OF ty_gl_master,

  " GL account text
  BEGIN OF ty_gl_text,
    racct  TYPE racct,
    text20 TYPE text20,
  END OF ty_gl_text,

  " GL account classification from zdt_r2r_fl_gls
  BEGIN OF ty_gl_class,
    gl_account TYPE saknr,
    identifier TYPE char10,
  END OF ty_gl_class,

  " Business Partner TIN (IS-U: dfkkbptaxnum)
  BEGIN OF ty_tax,
    partner TYPE bu_partner,
    taxnum  TYPE dfkkbptaxnum-taxnum,
  END OF ty_tax,

  " BP address assignment (but020)
  BEGIN OF ty_bp_addr,
    partner    TYPE bu_partner,
    addrnumber TYPE adrnr,
  END OF ty_bp_addr,

  " Address data (adrc)
  BEGIN OF ty_adrc,
    addrnumber TYPE adrnr,
    name1      TYPE ad_name1,
    name2      TYPE ad_name2,
    name3      TYPE ad_name3,
    name4      TYPE ad_name4,
    street     TYPE ad_street,
    str_suppl1 TYPE ad_strspp1,
    str_suppl2 TYPE ad_strspp2,
    str_suppl3 TYPE ad_strspp3,
    location   TYPE ad_lcity2,
    city1      TYPE ad_city1,
  END OF ty_adrc,

  " Customer sales area (from I_CustomerSalesArea)
  BEGIN OF ty_knvv,
    kunnr TYPE kunnr,
    vkorg TYPE vkorg,
    vtweg TYPE vtweg,
    spart TYPE spart,
    vkbur TYPE vkbur,
  END OF ty_knvv,

  " Master output structure -- covers all 3 report modes
  BEGIN OF ty_output,
    " Common (all modes)
    budat          TYPE string,
    tin            TYPE string,
    reg_name       TYPE string,
    address1       TYPE string,
    address2       TYPE string,
    " Sales Journal specific (columns C-S)
    total_amt      TYPE wrbtr,
    non_revenue    TYPE wrbtr,
    revenue        TYPE wrbtr,
    nft            TYPE wrbtr,
    lft            TYPE wrbtr,
    vat_amt        TYPE wrbtr,
    discount       TYPE wrbtr,
    bktxt          TYPE string,
    reference      TYPE string,
    belnr          TYPE belnr_d,
    invoice_no     TYPE xblnr1,
    dm_no          TYPE string,
    " Summary List specific (columns T-AA)
    notq_vat       TYPE wrbtr,
    exempt         TYPE wrbtr,
    zero_rated     TYPE wrbtr,
    taxable_net    TYPE wrbtr,
    output_vat     TYPE wrbtr,
    total_sales    TYPE wrbtr,
    gross_tax      TYPE wrbtr,
    " Detailed List additional fields
    inv_dm_date    TYPE string,
    bill_period    TYPE string,
    posting_key    TYPE bschl,
    document_type  TYPE blart,
    vat_code       TYPE mwskz,
    wht_code       TYPE string,    " always blank per FS assumption D
    bp_code        TYPE kunnr,
    bukrs          TYPE bukrs,
    bupla          TYPE bupla,
    sales_office   TYPE vkbur,
    prctr          TYPE prctr,
    ar_gl_no       TYPE saknr,
    ar_gl_name     TYPE string,
    cr_gl_no       TYPE saknr,
    cr_gl_name     TYPE string,
  END OF ty_output,

  " Execution log (written to ZAB_R2R_SALES_LOG)
  BEGIN OF ty_log,
    mandt         TYPE mandt,
    bukrs         TYPE bukrs,
    budat_from    TYPE budat,
    budat_to      TYPE budat,
    gjahr         TYPE gjahr,
    kunnr         TYPE kunnr,
    output_option TYPE char5,
    usnam         TYPE syuname,
    cpudt         TYPE sydatum,
    cputm         TYPE syuzeit,
  END OF ty_log,

  " Field catalog entry for column label assignment
  BEGIN OF ty_fieldcat,
    fieldname  TYPE lvc_fname,
    coltext_l  TYPE scrtext_l,
    coltext_m  TYPE scrtext_m,
    coltext_s  TYPE scrtext_s,
  END OF ty_fieldcat.

"--- Sorted table types for binary-search lookups ---
TYPES:
  ty_bkpf_tab   TYPE SORTED TABLE OF ty_bkpf    WITH UNIQUE KEY bukrs belnr gjahr,
  ty_acdoca_tab TYPE STANDARD TABLE OF ty_acdoca WITH EMPTY KEY,
  ty_gl_cls_tab TYPE SORTED TABLE OF ty_gl_class WITH NON-UNIQUE KEY gl_account identifier,
  ty_gl_mst_tab TYPE SORTED TABLE OF ty_gl_master WITH UNIQUE KEY racct,
  ty_gl_txt_tab TYPE SORTED TABLE OF ty_gl_text   WITH UNIQUE KEY racct,
  ty_tax_tab    TYPE SORTED TABLE OF ty_tax       WITH NON-UNIQUE KEY partner,
  ty_addr_tab   TYPE SORTED TABLE OF ty_bp_addr   WITH NON-UNIQUE KEY partner,
  ty_adrc_tab   TYPE SORTED TABLE OF ty_adrc      WITH UNIQUE KEY addrnumber,
  ty_knvv_tab   TYPE SORTED TABLE OF ty_knvv      WITH NON-UNIQUE KEY kunnr vkorg vtweg spart.

"--- TVARVC range types ---
TYPES:
  ty_r_racct TYPE RANGE OF racct,
  ty_r_mwskz TYPE RANGE OF mwskz.

"--- Global variables ---
DATA:
  gt_output   TYPE STANDARD TABLE OF ty_output WITH EMPTY KEY,
  gt_out_tab  TYPE string_table,    " formatted lines for file download
  gt_creaflow TYPE STANDARD TABLE OF l_s_creaflow WITH EMPTY KEY,
  gv_mode     TYPE char2.           " gc_sj / gc_sl / gc_dl

TYPES:
  BEGIN OF l_s_creaflow,
    string TYPE string,
    label  TYPE char1,
  END OF l_s_creaflow.
